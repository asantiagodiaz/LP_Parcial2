    COMA            shift and go to state 75
    CORCHETE_DER    reduce using rule 30 (lista -> valor .)


state 74

    (28) valor -> CORCHETE_IZQ lista CORCHETE_DER .

    Y               reduce using rule 28 (valor -> CORCHETE_IZQ lista CORCHETE_DER .)
    O               reduce using rule 28 (valor -> CORCHETE_IZQ lista CORCHETE_DER .)
    PUNTO_COMA      reduce using rule 28 (valor -> CORCHETE_IZQ lista CORCHETE_DER .)
    CON             reduce using rule 28 (valor -> CORCHETE_IZQ lista CORCHETE_DER .)
    COMA            reduce using rule 28 (valor -> CORCHETE_IZQ lista CORCHETE_DER .)
    LLAVE_DER       reduce using rule 28 (valor -> CORCHETE_IZQ lista CORCHETE_DER .)
    CORCHETE_DER    reduce using rule 28 (valor -> CORCHETE_IZQ lista CORCHETE_DER .)


state 75

    (29) lista -> valor COMA . lista
    (29) lista -> . valor COMA lista
    (30) lista -> . valor
    (31) lista -> .
    (23) valor -> . CADENA
    (24) valor -> . NUMERO
    (25) valor -> . VERDADERO
    (26) valor -> . FALSO
    (27) valor -> . documento
    (28) valor -> . CORCHETE_IZQ lista CORCHETE_DER
    (19) documento -> . LLAVE_IZQ pares LLAVE_DER

    CORCHETE_DER    reduce using rule 31 (lista -> .)
    CADENA          shift and go to state 62
    NUMERO          shift and go to state 64
